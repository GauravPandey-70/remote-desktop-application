# ============================================
# DeskLink — Environment Configuration
# Copy to .env and fill in values
# ============================================

# --- General ---
NODE_ENV=development
LOG_LEVEL=debug

# --- PostgreSQL ---
DATABASE_URL=postgresql://desklink:desklink_dev@localhost:5432/desklink
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Signaling Server ---
SIGNALING_PORT=8080
SIGNALING_HOST=0.0.0.0

# --- API Server ---
API_PORT=3000
API_HOST=0.0.0.0

# --- JWT ---
JWT_SECRET=change-me-in-production-use-a-64-char-random-string
JWT_EXPIRES_IN=7d

# --- TURN Server ---
TURN_SERVER_URL=turn:localhost:3478
TURN_SERVER_USERNAME=desklink
TURN_SERVER_PASSWORD=desklink_turn_dev
TURN_SERVER_REALM=desklink.local

# --- STUN Server ---
STUN_SERVER_URL=stun:stun.l.google.com:19302

# --- Passcode ---
PASSCODE_LENGTH=6
PASSCODE_EXPIRY_MINUTES=10
PASSCODE_MAX_ATTEMPTS=5
PASSCODE_LOCKOUT_MINUTES=30

# --- Auto-Update ---
UPDATE_SERVER_URL=https://updates.desklink.io
